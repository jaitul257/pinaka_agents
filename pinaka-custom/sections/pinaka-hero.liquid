<!-- pinaka-custom.css loaded globally via theme.liquid -->

<div class="pinaka-hero color-{{ section.settings.color_scheme }}">
  <div>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subtext }}</p>
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="cta">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
  <div class="hero-img">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1200 }}"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        width="1200"
        height="{{ 1200 | divided_by: section.settings.image.aspect_ratio | round }}"
        loading="eager"
      >
    {%- else -%}
      <img
        src="{{ 'on_hand_bracelet.png' | asset_url }}"
        alt="Diamond tennis bracelet on wrist"
        loading="eager"
        style="width:100%;height:100%;object-fit:cover;"
      >
    {%- endif -%}
  </div>
</div>
<div class="pinaka-rule"></div>

{% schema %}
{
  "name": "Pinaka Hero",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Handcrafted to Adorn." },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Diamond tennis bracelets, handset to order in 15 business days." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Bracelets" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" }
  ],
  "presets": [{ "name": "Pinaka Hero" }]
}
{% endschema %}
