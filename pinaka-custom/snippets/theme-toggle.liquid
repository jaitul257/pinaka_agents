{% doc %}
  Renders a light/dark theme toggle button.
  
  @example
  {% render 'theme-toggle' %}
{% enddoc %}

<div class="theme-toggle-container" id="themeToggleContainer">
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
    <svg class="theme-toggle__icon theme-toggle__icon--light" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"></circle>
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
    <svg class="theme-toggle__icon theme-toggle__icon--dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </button>
  <span class="theme-toggle__label" id="themeLabel">Light</span>
</div>

{% stylesheet %}
  .theme-toggle-container {
    position: fixed;
    bottom: 20px;
    left: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 1000;
  }

  .theme-toggle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(44, 40, 37, 0.1);
    border: 1px solid rgba(44, 40, 37, 0.2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .theme-toggle:hover {
    background: rgba(44, 40, 37, 0.15);
    border-color: rgba(44, 40, 37, 0.3);
  }

  .theme-toggle__icon {
    width: 20px;
    height: 20px;
    color: var(--pinaka-charcoal);
    transition: opacity 0.3s ease;
  }

  .theme-toggle__icon--light {
    opacity: 1;
  }

  .theme-toggle__icon--dark {
    opacity: 0;
    position: absolute;
  }

  .theme-toggle__label {
    font-size: 12px;
    font-weight: 500;
    color: var(--pinaka-charcoal);
    letter-spacing: 0.5px;
    white-space: nowrap;
    border: 1px solid rgba(44, 40, 37, 0.2);
    padding: 6px 12px;
    border-radius: 20px;
    transition: all 0.3s ease;
  }

  /* Dark mode styles */
  body.dark-mode {
    background-color: #1a1815 !important;
  }

  body.dark-mode *:not(img):not(svg) {
    background-color: transparent !important;
  }

  body.dark-mode .header {
    background-color: #2C2825 !important;
  }

  body.dark-mode h1,
  body.dark-mode h2,
  body.dark-mode h3,
  body.dark-mode h4,
  body.dark-mode h5,
  body.dark-mode h6,
  body.dark-mode p,
  body.dark-mode span,
  body.dark-mode div,
  body.dark-mode section,
  body.dark-mode article,
  body.dark-mode main,
  body.dark-mode li {
    color: #FAF7F2 !important;
    background-color: transparent !important;
  }

  body.dark-mode .header__heading-link .h2 {
    color: #FAF7F2 !important;
  }

  body.dark-mode button,
  body.dark-mode .button,
  body.dark-mode a.button,
  body.dark-mode .cta {
    background-color: #D4A017 !important;
    color: #2C2825 !important;
    padding: 14px 36px !important;
    border-radius: 8px !important;
  }

  body.dark-mode button:hover,
  body.dark-mode .button:hover,
  body.dark-mode a.button:hover,
  body.dark-mode .cta:hover {
    background-color: #B8890F !important;
  }

  body.dark-mode footer {
    background-color: #2C2825 !important;
  }

  body.dark-mode a {
    color: #D4A017 !important;
  }

  body.dark-mode a.button,
  body.dark-mode .cta {
    color: #2C2825 !important;
  }

  body.dark-mode .card {
    background-color: #3a3630 !important;
    border: 1px solid rgba(212, 160, 23, 0.25) !important;
    border-radius: 8px;
  }

  body.dark-mode .card__content {
    background-color: transparent !important;
  }

  body.dark-mode .card__information {
    background-color: transparent !important;
  }

  body.dark-mode .card__image {
    background-color: #3a3630 !important;
  }

  body.dark-mode img {
    opacity: 1 !important;
    display: block !important;
  }

  body.dark-mode blockquote {
    color: #D4D0CA !important;
  }

  body.dark-mode .rich-text {
    color: #D4D0CA !important;
  }

  body.dark-mode hr,
  body.dark-mode .divider,
  body.dark-mode .section-divider {
    border-color: rgba(212, 160, 23, 0.4) !important;
    background-color: rgba(212, 160, 23, 0.4) !important;
  }

  body.dark-mode .timeline__label,
  body.dark-mode .timeline__item-label {
    color: #D4A017 !important;
  }

  body.dark-mode .timeline__heading,
  body.dark-mode .timeline__item-heading {
    color: #FAF7F2 !important;
  }

  body.dark-mode .timeline__description,
  body.dark-mode .timeline__item-description {
    color: #D4D0CA !important;
  }

  body.dark-mode .rte,
  body.dark-mode .prose {
    overflow-x: auto !important;
    word-wrap: break-word !important;
  }

  body.dark-mode .theme-toggle {
    background: rgba(250, 247, 242, 0.1);
    border-color: rgba(250, 247, 242, 0.2);
  }

  body.dark-mode .theme-toggle:hover {
    background: rgba(250, 247, 242, 0.15);
    border-color: rgba(250, 247, 242, 0.3);
  }

  body.dark-mode .theme-toggle__icon {
    color: #FAF7F2;
  }

  body.dark-mode .theme-toggle__icon--light {
    opacity: 0;
  }

  body.dark-mode .theme-toggle__icon--dark {
    opacity: 1;
  }

  body.dark-mode .theme-toggle__label {
    color: #FAF7F2;
    border-color: rgba(250, 247, 242, 0.2);
  }
{% endstylesheet %}

{% javascript %}
  const themeToggle = document.getElementById('themeToggle');
  const themeLabel = document.getElementById('themeLabel');
  const htmlElement = document.documentElement;

  // Check for saved theme preference
  const savedTheme = localStorage.getItem('theme') || 'light';
  if (savedTheme === 'dark') {
    document.body.classList.add('dark-mode');
    themeLabel.textContent = 'Dark';
  }

  themeToggle.addEventListener('click', () => {
    document.body.classList.toggle('dark-mode');
    const currentTheme = document.body.classList.contains('dark-mode') ? 'dark' : 'light';
    themeLabel.textContent = currentTheme.charAt(0).toUpperCase() + currentTheme.slice(1);
    localStorage.setItem('theme', currentTheme);
  });
{% endjavascript %}

