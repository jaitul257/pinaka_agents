{% doc %}
  Renders a light/dark theme toggle button.
  
  @example
  {% render 'theme-toggle' %}
{% enddoc %}

<div class="theme-toggle-container" id="themeToggleContainer">
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
    <svg class="theme-toggle__icon theme-toggle__icon--light" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"></circle>
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
    <svg class="theme-toggle__icon theme-toggle__icon--dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
  </button>
  <span class="theme-toggle__label" id="themeLabel">Light</span>
</div>

{% stylesheet %}
  .theme-toggle-container {
    position: fixed;
    bottom: 20px;
    left: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 1000;
  }

  .theme-toggle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(44, 40, 37, 0.1);
    border: 1px solid rgba(44, 40, 37, 0.2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .theme-toggle:hover {
    background: rgba(44, 40, 37, 0.15);
    border-color: rgba(44, 40, 37, 0.3);
  }

  .theme-toggle__icon {
    width: 20px;
    height: 20px;
    color: var(--pinaka-charcoal);
    transition: opacity 0.3s ease;
  }

  .theme-toggle__icon--light {
    opacity: 1;
  }

  .theme-toggle__icon--dark {
    opacity: 0;
    position: absolute;
  }

  .theme-toggle__label {
    font-size: 12px;
    font-weight: 500;
    color: var(--pinaka-charcoal);
    letter-spacing: 0.5px;
    white-space: nowrap;
    border: 1px solid rgba(44, 40, 37, 0.2);
    padding: 6px 12px;
    border-radius: 20px;
    transition: all 0.3s ease;
  }

  /* ── Dark mode ──
     Targeted overrides only. No wildcard * rules that break Dawn's
     dropdowns, modals, cart drawer, predictive search, or newsletter popups.
     Each rule targets a specific Dawn element or Pinaka section. */

  body.dark-mode {
    background-color: #1a1815 !important;
    color: #FAF7F2;
  }

  /* Dawn layout containers */
  body.dark-mode .color-scheme-1,
  body.dark-mode .color-scheme-2,
  body.dark-mode .color-scheme-3 {
    background-color: #1a1815 !important;
    color: #FAF7F2;
  }

  body.dark-mode .header {
    background-color: #2C2825 !important;
  }

  body.dark-mode footer,
  body.dark-mode .footer {
    background-color: #2C2825 !important;
  }

  /* Text colors */
  body.dark-mode h1,
  body.dark-mode h2,
  body.dark-mode h3,
  body.dark-mode h4,
  body.dark-mode .h1,
  body.dark-mode .h2,
  body.dark-mode .h3 {
    color: #FAF7F2 !important;
  }

  body.dark-mode p,
  body.dark-mode li,
  body.dark-mode .rte,
  body.dark-mode .prose {
    color: #D4D0CA !important;
  }

  body.dark-mode .header__heading-link,
  body.dark-mode .header__heading-link .h2 {
    color: #FAF7F2 !important;
  }

  /* Buttons — only primary CTA buttons, not Dawn UI controls */
  body.dark-mode .button--primary,
  body.dark-mode .shopify-payment-button__button,
  body.dark-mode .cta {
    background-color: #D4A017 !important;
    color: #2C2825 !important;
  }

  body.dark-mode .button--primary:hover,
  body.dark-mode .cta:hover {
    background-color: #B8890F !important;
  }

  /* Links */
  body.dark-mode a:not(.button):not(.cta) {
    color: #D4A017;
  }

  /* Product cards */
  body.dark-mode .card,
  body.dark-mode .card-wrapper .card {
    background-color: transparent !important;
    border: none !important;
    box-shadow: none !important;
  }

  body.dark-mode .card__inner,
  body.dark-mode .card .card__media,
  body.dark-mode .card__media {
    background: radial-gradient(ellipse at 50% 40%, rgba(212, 160, 23, 0.05) 0%, transparent 60%),
      linear-gradient(155deg, #1f1d1a, #151310) !important;
    border: 1px solid rgba(250, 247, 242, 0.06) !important;
    border-radius: 6px !important;
  }

  body.dark-mode .card__content,
  body.dark-mode .card__information,
  body.dark-mode .card-information {
    background-color: transparent !important;
    padding-top: 14px !important;
  }

  body.dark-mode .card__heading,
  body.dark-mode .card__heading a {
    color: #FAF7F2 !important;
  }

  body.dark-mode .price,
  body.dark-mode .price-item {
    color: #D4D0CA !important;
  }

  /* Blockquotes / rich text */
  body.dark-mode blockquote {
    color: #D4D0CA !important;
  }

  /* Dividers */
  body.dark-mode hr,
  body.dark-mode .divider {
    border-color: rgba(250, 247, 242, 0.12) !important;
  }

  /* Dawn interactive components — keep their backgrounds functional */
  body.dark-mode .cart-drawer,
  body.dark-mode .menu-drawer,
  body.dark-mode .modal__content,
  body.dark-mode .predictive-search,
  body.dark-mode .disclosure__list-wrapper {
    background-color: #2C2825 !important;
    color: #FAF7F2 !important;
  }

  body.dark-mode .cart-drawer a,
  body.dark-mode .menu-drawer a,
  body.dark-mode .modal__content a {
    color: #FAF7F2 !important;
  }

  /* Pinaka custom sections */
  body.dark-mode .pinaka-hero {
    background-color: #1a1815;
  }

  body.dark-mode .pinaka-craft-timeline__step {
    background-color: rgba(250, 247, 242, 0.03) !important;
    border: 1px solid rgba(250, 247, 242, 0.1) !important;
    box-shadow: none !important;
  }

  body.dark-mode .pinaka-founder-note {
    background-color: rgba(212, 160, 23, 0.06) !important;
  }

  body.dark-mode .pinaka-ledger__entry {
    border-bottom-color: rgba(250, 247, 242, 0.12) !important;
  }

  body.dark-mode .theme-toggle {
    background: rgba(250, 247, 242, 0.1);
    border-color: rgba(250, 247, 242, 0.2);
  }

  body.dark-mode .theme-toggle:hover {
    background: rgba(250, 247, 242, 0.15);
    border-color: rgba(250, 247, 242, 0.3);
  }

  body.dark-mode .theme-toggle__icon {
    color: #FAF7F2;
  }

  body.dark-mode .theme-toggle__icon--light {
    opacity: 0;
  }

  body.dark-mode .theme-toggle__icon--dark {
    opacity: 1;
  }

  body.dark-mode .theme-toggle__label {
    color: #FAF7F2;
    border-color: rgba(250, 247, 242, 0.2);
  }
{% endstylesheet %}

{% javascript %}
  const themeToggle = document.getElementById('themeToggle');
  const themeLabel = document.getElementById('themeLabel');
  const htmlElement = document.documentElement;

  // Check for saved theme preference
  const savedTheme = localStorage.getItem('theme') || 'light';
  if (savedTheme === 'dark') {
    document.body.classList.add('dark-mode');
    themeLabel.textContent = 'Dark';
  }

  themeToggle.addEventListener('click', () => {
    document.body.classList.toggle('dark-mode');
    const currentTheme = document.body.classList.contains('dark-mode') ? 'dark' : 'light';
    themeLabel.textContent = currentTheme.charAt(0).toUpperCase() + currentTheme.slice(1);
    localStorage.setItem('theme', currentTheme);
  });
{% endjavascript %}

