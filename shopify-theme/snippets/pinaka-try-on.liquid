{%- if request.page_type == 'product' -%}
<style>
  .pinaka-tryon-btn {
    position: fixed;
    bottom: 88px;
    right: 24px;
    background: var(--pinaka-accent, #D4A017);
    color: var(--pinaka-charcoal, #2C2825);
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 16px;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    z-index: 9998;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: transform 0.3s ease, opacity 0.3s ease, box-shadow 0.2s;
  }
  .pinaka-tryon-btn:hover { transform: scale(1.04); box-shadow: 0 6px 24px rgba(0,0,0,0.2); }
  .pinaka-tryon-btn.scroll-hidden {
    transform: translateY(calc(100% + 30px));
    opacity: 0;
    pointer-events: none;
  }
  .pinaka-tryon-btn svg { width: 16px; height: 16px; }

  .pinaka-tryon-overlay {
    position: fixed;
    inset: 0;
    background: rgba(44, 40, 37, 0.5);
    z-index: 10000;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .pinaka-tryon-overlay.open { display: flex; }

  .pinaka-tryon-modal {
    background: var(--pinaka-cream, #FAF7F2);
    border-radius: 16px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.2);
    width: 480px;
    max-width: calc(100vw - 32px);
    max-height: 90vh;
    overflow-y: auto;
    font-family: 'DM Sans', sans-serif;
  }

  .pinaka-tryon-header {
    background: #2C2825;
    color: #FAF7F2;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: 16px 16px 0 0;
  }
  .pinaka-tryon-header__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 400;
  }
  .pinaka-tryon-close {
    background: none;
    border: none;
    color: #FAF7F2;
    cursor: pointer;
    font-size: 22px;
    padding: 0;
    line-height: 1;
  }

  .pinaka-tryon-body { padding: 24px; }

  .pinaka-tryon-upload {
    border: 2px dashed var(--pinaka-border, #E8E2D9);
    border-radius: 12px;
    padding: 40px 24px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .pinaka-tryon-upload:hover { border-color: var(--pinaka-accent, #D4A017); }
  .pinaka-tryon-upload svg { width: 48px; height: 48px; color: var(--pinaka-muted, #9E9893); margin-bottom: 12px; }
  .pinaka-tryon-upload__text {
    font-size: 15px;
    color: var(--pinaka-charcoal, #2C2825);
    font-weight: 500;
    margin-bottom: 4px;
  }
  .pinaka-tryon-upload__hint {
    font-size: 12px;
    color: var(--pinaka-muted, #9E9893);
  }

  .pinaka-tryon-preview img {
    width: 100%;
    border-radius: 10px;
    margin-bottom: 16px;
  }
  .pinaka-tryon-product {
    font-family: 'Cormorant Garamond', serif;
    font-size: 18px;
    color: var(--pinaka-charcoal, #2C2825);
    margin-bottom: 12px;
  }

  .pinaka-tryon-generate {
    width: 100%;
    padding: 14px;
    background: var(--pinaka-accent, #D4A017);
    color: var(--pinaka-charcoal, #2C2825);
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .pinaka-tryon-generate:hover { background: var(--pinaka-accent-hover, #B8890F); }
  .pinaka-tryon-generate:disabled { opacity: 0.5; cursor: default; }

  .pinaka-tryon-loading {
    text-align: center;
    padding: 32px 0;
  }
  .pinaka-tryon-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--pinaka-border, #E8E2D9);
    border-top-color: var(--pinaka-accent, #D4A017);
    border-radius: 50%;
    animation: tryon-spin 0.8s linear infinite;
    margin: 0 auto 16px;
  }
  @keyframes tryon-spin { to { transform: rotate(360deg); } }
  .pinaka-tryon-loading__text {
    font-size: 14px;
    color: var(--pinaka-text2, #6B6560);
  }

  .pinaka-tryon-result img {
    width: 100%;
    border-radius: 10px;
    margin-bottom: 16px;
  }
  .pinaka-tryon-actions {
    display: flex;
    gap: 10px;
  }
  .pinaka-tryon-actions .btn-secondary {
    flex: 1;
    padding: 12px;
    background: transparent;
    border: 1px solid var(--pinaka-border, #E8E2D9);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--pinaka-charcoal, #2C2825);
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .pinaka-tryon-actions .btn-secondary:hover { border-color: var(--pinaka-accent); }
  .pinaka-tryon-actions .btn-primary {
    flex: 1;
    padding: 12px;
    background: var(--pinaka-accent, #D4A017);
    color: var(--pinaka-charcoal, #2C2825);
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    transition: background 0.2s;
  }
  .pinaka-tryon-actions .btn-primary:hover { background: var(--pinaka-accent-hover, #B8890F); }

  .pinaka-tryon-error {
    text-align: center;
    padding: 24px 0;
  }
  .pinaka-tryon-error__msg {
    font-size: 14px;
    color: var(--pinaka-text2, #6B6560);
    margin-bottom: 16px;
  }

  /* Mobile */
  @media (max-width: 749px) {
    .pinaka-tryon-btn {
      bottom: 72px;
      right: 12px;
      font-size: 12px;
      padding: 8px 12px;
    }
    .pinaka-tryon-modal {
      width: 100vw;
      max-width: 100vw;
      max-height: 100dvh;
      border-radius: 0;
      height: 100dvh;
    }
    .pinaka-tryon-header { border-radius: 0; }
    .pinaka-tryon-body { padding: 16px; }
  }

  /* Dark mode */
  body.dark-mode .pinaka-tryon-modal { background: #1a1815; }
  body.dark-mode .pinaka-tryon-upload { border-color: rgba(250,247,242,0.15); }
  body.dark-mode .pinaka-tryon-upload__text { color: #FAF7F2; }
  body.dark-mode .pinaka-tryon-product { color: #FAF7F2; }
  body.dark-mode .pinaka-tryon-actions .btn-secondary { color: #FAF7F2; border-color: rgba(250,247,242,0.2); }
</style>

<!-- Try-On Button -->
<button class="pinaka-tryon-btn" id="pinakaTryOnBtn" aria-label="Virtual try-on">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10"/><path d="M8 12a4 4 0 0 0 8 0"/></svg>
  Try it on
</button>

<!-- Modal Overlay -->
<div class="pinaka-tryon-overlay" id="pinakaTryOnOverlay">
  <div class="pinaka-tryon-modal">
    <div class="pinaka-tryon-header">
      <span class="pinaka-tryon-header__title">Virtual Try-On</span>
      <button class="pinaka-tryon-close" id="pinakaTryOnClose">&times;</button>
    </div>
    <div class="pinaka-tryon-body" id="pinakaTryOnBody">
      <!-- Upload state (default) -->
      <div id="tryonUpload">
        <div class="pinaka-tryon-upload" id="tryonDropZone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><path d="M12 16V8m0 0l-3 3m3-3l3 3"/><path d="M3 16v1a4 4 0 004 4h10a4 4 0 004-4v-1"/></svg>
          <div class="pinaka-tryon-upload__text">Upload a wrist photo</div>
          <div class="pinaka-tryon-upload__hint">Hold your wrist centered in the frame</div>
        </div>
        <input type="file" id="tryonFileInput" accept="image/jpeg,image/png,image/webp" capture="environment" style="display:none;">
      </div>

      <!-- Preview state -->
      <div id="tryonPreview" style="display:none;">
        <div class="pinaka-tryon-preview">
          <img id="tryonPreviewImg" alt="Your wrist photo">
        </div>
        <div class="pinaka-tryon-product">{{ product.title }}</div>
        <button class="pinaka-tryon-generate" id="tryonGenerateBtn">Generate Try-On</button>
      </div>

      <!-- Loading state -->
      <div id="tryonLoading" style="display:none;">
        <div class="pinaka-tryon-loading">
          <div class="pinaka-tryon-spinner"></div>
          <div class="pinaka-tryon-loading__text" id="tryonLoadingText">Analyzing your photo...</div>
        </div>
      </div>

      <!-- Result state -->
      <div id="tryonResult" style="display:none;">
        <div class="pinaka-tryon-result">
          <img id="tryonResultImg" alt="Try-on result">
        </div>
        <div class="pinaka-tryon-product">{{ product.title }}</div>
        <div style="font-family:'Geist Mono',monospace;font-size:18px;color:var(--pinaka-charcoal,#2C2825);margin-bottom:16px;">{{ product.selected_or_first_available_variant.price | money }}</div>
        <div class="pinaka-tryon-actions">
          <button class="btn-secondary" id="tryonRetryBtn">Try Another Photo</button>
          <a href="{{ product.url }}" class="btn-primary">Shop Now</a>
        </div>
      </div>

      <!-- Error state -->
      <div id="tryonError" style="display:none;">
        <div class="pinaka-tryon-error">
          <div class="pinaka-tryon-error__msg" id="tryonErrorMsg">Something went wrong.</div>
          <button class="pinaka-tryon-generate" id="tryonRetryFromError">Try Again</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var API = '{{ shop.metafields.pinaka.chat_api.value | default: "https://pinaka-agents-production-198b5.up.railway.app" }}';
  var HANDLE = '{{ product.handle }}';

  var btn = document.getElementById('pinakaTryOnBtn');
  var overlay = document.getElementById('pinakaTryOnOverlay');
  var closeBtn = document.getElementById('pinakaTryOnClose');
  var dropZone = document.getElementById('tryonDropZone');
  var fileInput = document.getElementById('tryonFileInput');
  var generateBtn = document.getElementById('tryonGenerateBtn');
  var retryBtn = document.getElementById('tryonRetryBtn');
  var retryErrorBtn = document.getElementById('tryonRetryFromError');
  var previewImg = document.getElementById('tryonPreviewImg');
  var resultImg = document.getElementById('tryonResultImg');
  var loadingText = document.getElementById('tryonLoadingText');
  var errorMsg = document.getElementById('tryonErrorMsg');

  var sections = ['tryonUpload', 'tryonPreview', 'tryonLoading', 'tryonResult', 'tryonError'];
  var wristBase64 = '';

  function showSection(id) {
    sections.forEach(function(s) {
      document.getElementById(s).style.display = s === id ? 'block' : 'none';
    });
  }

  // Open/close modal
  btn.addEventListener('click', function() {
    overlay.classList.add('open');
    btn.style.display = 'none';
  });
  closeBtn.addEventListener('click', function() {
    overlay.classList.remove('open');
    btn.style.display = 'flex';
  });
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) {
      overlay.classList.remove('open');
      btn.style.display = 'flex';
    }
  });

  // File upload
  dropZone.addEventListener('click', function() { fileInput.click(); });
  fileInput.addEventListener('change', function() {
    var file = fileInput.files[0];
    if (!file) return;
    if (file.size > 10 * 1024 * 1024) {
      alert('Image too large. Please use a photo under 10MB.');
      return;
    }
    resizeImage(file, 1024, function(b64) {
      wristBase64 = b64;
      previewImg.src = b64;
      showSection('tryonPreview');
    });
  });

  // Resize image client-side
  function resizeImage(file, maxDim, cb) {
    var img = new Image();
    img.onload = function() {
      var scale = Math.min(1, maxDim / Math.max(img.width, img.height));
      var canvas = document.createElement('canvas');
      canvas.width = Math.round(img.width * scale);
      canvas.height = Math.round(img.height * scale);
      canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
      cb(canvas.toDataURL('image/jpeg', 0.85));
    };
    img.src = URL.createObjectURL(file);
  }

  // Generate try-on
  generateBtn.addEventListener('click', function() {
    showSection('tryonLoading');
    var msgs = ['Analyzing your photo...', 'Compositing bracelet...', 'Matching lighting...', 'Almost there...'];
    var mi = 0;
    var msgInterval = setInterval(function() {
      mi = (mi + 1) % msgs.length;
      loadingText.textContent = msgs[mi];
    }, 4000);

    fetch(API + '/api/try-on', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ wrist_image: wristBase64, product_handle: HANDLE })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      clearInterval(msgInterval);
      if (data.status === 'success' && data.result_url) {
        resultImg.src = data.result_url;
        showSection('tryonResult');
      } else {
        errorMsg.textContent = data.message || 'Something went wrong. Please try a different photo.';
        showSection('tryonError');
      }
    })
    .catch(function() {
      clearInterval(msgInterval);
      errorMsg.textContent = 'Connection error. Please check your internet and try again.';
      showSection('tryonError');
    });
  });

  // Retry buttons
  retryBtn.addEventListener('click', function() {
    wristBase64 = '';
    fileInput.value = '';
    showSection('tryonUpload');
  });
  retryErrorBtn.addEventListener('click', function() {
    if (wristBase64) {
      showSection('tryonPreview');
    } else {
      fileInput.value = '';
      showSection('tryonUpload');
    }
  });

  // Scroll-hide button (same pattern as chat widget)
  var lastY = window.scrollY;
  window.addEventListener('scroll', function() {
    if (overlay.classList.contains('open')) return;
    var y = window.scrollY;
    if (y > lastY && y > 100) {
      btn.classList.add('scroll-hidden');
    } else {
      btn.classList.remove('scroll-hidden');
    }
    lastY = y;
  }, { passive: true });
})();
</script>
{%- endif -%}
